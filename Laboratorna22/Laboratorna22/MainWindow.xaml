<Window x:Class="Laboratorna22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laboratorna22 - WPF Text Editor"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed"/>
    </Window.CommandBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8">
            <WrapPanel VerticalAlignment="Center">
                <Button x:Name="btnOpen" Content="Відкрити" Width="90" Height="32" Margin="3" Command="ApplicationCommands.Open"/>
                <Button x:Name="btnSave" Content="Зберегти" Width="90" Height="32" Margin="3" Command="ApplicationCommands.Save"/>

                <Separator Width="15"/>

                <ToggleButton x:Name="btnBold" Content="B" Width="38" Height="32" Margin="3" FontWeight="Bold" Command="EditingCommands.ToggleBold"/>
                <ToggleButton x:Name="btnItalic" Content="I" Width="38" Height="32" Margin="3" FontStyle="Italic" Command="EditingCommands.ToggleItalic"/>
                <ToggleButton x:Name="btnUnderline" Width="38" Height="32" Margin="3" Command="EditingCommands.ToggleUnderline">
                    <TextBlock Text="U" TextDecorations="Underline"/>
                </ToggleButton>

                <Separator Width="15"/>

                <ComboBox x:Name="cmbFontFamily"
                          Width="170"
                          Height="32"
                          Margin="3"
                          SelectionChanged="cmbFontFamily_SelectionChanged"/>

                <ComboBox x:Name="cmbFontSize"
                          Width="80"
                          Height="32"
                          Margin="3"
                          IsEditable="True"
                          SelectionChanged="cmbFontSize_SelectionChanged"
                          TextBoxBase.TextChanged="cmbFontSize_TextChanged"/>

                <Separator Width="15"/>

                <Button x:Name="btnLeft" Content="Ліворуч" Width="85" Height="32" Margin="3" Click="AlignLeft_Click"/>
                <Button x:Name="btnCenter" Content="Центр" Width="85" Height="32" Margin="3" Click="AlignCenter_Click"/>
                <Button x:Name="btnRight" Content="Праворуч" Width="85" Height="32" Margin="3" Click="AlignRight_Click"/>

                <Separator Width="15"/>

                <ComboBox x:Name="cmbLanguage" Width="130" Height="32" Margin="3" SelectionChanged="cmbLanguage_SelectionChanged">
                    <ComboBoxItem Content="Українська" IsSelected="True"/>
                    <ComboBoxItem Content="English"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#2D2D30" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Символів: 0"/>
            </StatusBarItem>
        </StatusBar>

        <Border Margin="14" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8">
            <RichTextBox x:Name="rtbEditor"
                         Margin="10"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="16"
                         AcceptsTab="True"
                         SelectionChanged="rtbEditor_SelectionChanged"
                         TextChanged="rtbEditor_TextChanged">
                <FlowDocument PagePadding="10">
                    <Paragraph>
                        <Run Text="Laboratorna22. WPF текстовий редактор."/>
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Border>
    </DockPanel>
</Window>